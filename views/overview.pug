extends base

block content 
    //- p=`Total cars = ${length}`
    main.main  
        .card-container
            
            each car in cars
                .card 
                    .card__header
                        .card__picture
                            .card__picture-overlay &nbsp;
                            img.card__picture-img(src=`/img/cars/${car.name}-cover.jpg`, alt=`${car.name}`)
                            //- img.card__picture-img(src="img/", alt=`${car.name}`)
                        h3.heading-tertirary
                            span= car.name

                    .card__details
                        h4.card__sub-heading= `${car.brand} `
                        //- p.card__text= car.summary  
                        .card__data
                            
                            svg.card__icon
                                use(xlink:href='/img/icons.svg#icon-user')
                                
                            span= car.seatingCapacity 
                        .card__data
                            //- svg.card__icon
                            <i class="fa fa-car" style="font-size:20px;margin-right:4px;color:#55c57a"></i>
                            span= car.bodyType 
                        .card__data
                            svg.card__icon
                                use(xlink:href='/img/icons.svg#icon-flag')
                            span= `${car.mileage} kmpl`
                        .card__data
                            <i class="fa fa-star" style="font-size:24px;margin-right:4px;color:#55c57a"></i>
                            span= `${car.engine} cc`
                        .card__data
                            <i class="fa fa-gear" style="font-size:24px;margin-right:4px;color:#55c57a"></i>
                            span= car.transmission 
                        .card__data
                            <i class="fa fa-assistive-listening-systems" style="font-size:20px;margin-right:4px;margin-right:4px;color:#55c57a"></i>
                            span= car.fuelType 

                    .card__footer
                        p
                            span.card__footer-value= `${car.price} Lack`
                            span.card__footer-text 
                        p.card__ratings
                            span.card__footer-value= `Rating: ${car.rating} / 5`
                            span.card__footer-text
                        a.btn.btn--green.btn--small(href=`/newCars/${car.name}`) Details 
                        // this might be a problem bcoz in the course he is using "slug" and V R using the names. Think carefully and then it will be resolved

    //- =================       Pagination     =================
    //- paginateURL : coming from newCarsController
    - if (!aliasRoues)
        .search__cars
            - for (var i = 1; i <= `${paginationBtnCount}`; i++)  
                a.btn.btn--small(class=`pagination__${i === paginationActiveBtn ? 'active' : 'inactive' }` href=`${paginateURL}page=${i}`)= `${i}`                      




