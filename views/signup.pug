extends base

block content 
    main.main
        .login-form
            h2.heading-secondary.ma-bt-lg Create a new account
            form.signup-form.form--login
                .form__group
                    label.form__label(for='name') Name 
                    input#name.form__input(type='text', placeholder='John Doe', required='required', value='test 3')
                .form__group
                    label.form__label(for='email') Email address 
                    input#email.form__input(type='email', placeholder='you@example.com', required='required', value='test3@gmail.com')
                .form__group.ma-bt-md
                    label.form__label(for='password') Password 
                    input#password.form__input(type='password', placeholder='••••••••', value='pass1234', required='required', minlength='8')
                .form__group.ma-bt-md
                    label.form__label(for='confirm-password') Confirm Password 
                    input#confirm-password.form__input(type='password', placeholder='••••••••', value='pass1234', required='required', minlength='8')
                .form__group
                    button.btn.btn--green Signup