extends base

block content
  main.main
    .login-form
      h2.heading-secondary.ma-bt-lg Log into your account
      form.form.form--login
        .form__group
          label.form__label(for='email') Email address            
          input#email.form__input(type='email', placeholder='you@example.com', required, value="test1@gmail.com")
        .form__group.ma-bt-md
          label.form__label(for='password') Password                
          input#password.form__input(type='password', placeholder='••••••••',value="pass1234", required, minlength='8')
        .form__group.form__btns
          button.btn.btn--green Login
          a.forgot-password(href="/api/v1/users/forgotPassword") Forgot Password

      

          