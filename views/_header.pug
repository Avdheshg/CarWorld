header.header
    nav.nav.nav--tours
        a.nav__el(href='/newCars') All Cars
    .header__logo
        a(href="/")
            img(src='/img/logo-white.png' alt='logo')
    nav.nav.nav--user
        if user
            //- a.nav__el.nav__el--logout(href='/login') Log out
            a.nav__el.nav__el--logout Log out
            a.nav__el(href='/me')
                img.nav__user-img(src=`/img/defaultUser.jpg` alt=`Photo of ${user.name}`)
                //- span= user.name.split(' ')[0]
        else
            a.nav__el(href='/login') Log in
            a.nav__el.nav__el--cta(href='#') Sign up

