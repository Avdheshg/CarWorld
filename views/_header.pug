.search__cars
    a.btn.btn--green.btn--small(href=`${url}&page=1&limit=5`)= 1 
    //- a.btn.btn--green.btn--small(href=`newCars?price[gte]=0&price[lte]=10&page=1&limit=5`) 1
    a.btn.btn--green.btn--small(href=`${url}&page=2&limit=5`)= 2 
    a.btn.btn--green.btn--small(href=`${url}&page=3&limit=5`) 3
    a.btn.btn--green.btn--small(href=`${url}&page=4&limit=5`) 4
    a.btn.btn--green.btn--small(href=`${url}&page=5&limit=5`) 5

