.filter-btns
    //- ================    Budget      ================
    .dropdown
        button.dropbtn Budget 
        .dropdown-content
            a(href="/newCars?price[gte]=0&price[lte]=10") 0-10L
            a(href="/newCars?price[gte]=10&price[lte]=20") 10-20L
            a(href="/newCars?price[gte]=20&price[lte]=30") 20-30L
            a(href="/newCars?price[gte]=30&price[lte]=40") 30-40L
            a(href="/newCars?price[gte]=50") Above 50L


    //- =============   Sort By    ================
    .dropdown
        button.dropbtn Sort By 
        .dropdown-content
            a(href="/newCars?sort=price") Price
            a(href="/newCars?sort=rating") Rating
            a(href="/newCars?sort=mileage") Mileage
            a(href="/newCars?sort=engine") Power
            a(href="/newCars?sort=seatingCapacity") Capacity

